<div class="dashboard-section">
  <div class="container py-5" style="margin-top: 70px;">
    <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
      <div>
        <h1 class="fw-bold mb-1"><i class="bi bi-people me-2 gradient-text"></i>Manage Users</h1>
        <p class="text-muted mb-0">View and manage registered advertisers</p>
      </div>
    </div>

    <div class="card border-0 shadow-sm" data-aos="fade-up">
      <div class="card-body p-4">
        <% if (users.length === 0) { %>
          <div class="text-center py-5">
            <div class="empty-state-icon mb-3"><i class="bi bi-people"></i></div>
            <h5 class="text-muted">No users yet</h5>
            <p class="text-muted">No advertisers have registered on the platform.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>User</th>
                  <th>Company</th>
                  <th>Phone</th>
                  <th>Ads</th>
                  <th>Status</th>
                  <th>Joined</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(user => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <div class="avatar-sm me-2">
                          <span><%= user.name.charAt(0).toUpperCase() %></span>
                        </div>
                        <div>
                          <h6 class="mb-0 fw-semibold small"><%= user.name %></h6>
                          <small class="text-muted"><%= user.email %></small>
                        </div>
                      </div>
                    </td>
                    <td><small><%= user.company || '-' %></small></td>
                    <td><small><%= user.phone || '-' %></small></td>
                    <td><span class="badge bg-primary-subtle text-primary"><%= user.adCount %> ads</span></td>
                    <td>
                      <% if (user.isActive) { %>
                        <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                      <% } else { %>
                        <span class="badge bg-danger-subtle text-danger"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                      <% } %>
                    </td>
                    <td><small class="text-muted"><%= new Date(user.createdAt).toLocaleDateString() %></small></td>
                    <td>
                      <form method="POST" action="/admin/user/<%= user._id %>/toggle" class="d-inline">
                        <button type="submit" class="btn btn-sm rounded-pill <%= user.isActive ? 'btn-outline-danger' : 'btn-outline-success' %>"
                          title="<%= user.isActive ? 'Deactivate' : 'Activate' %>">
                          <i class="bi <%= user.isActive ? 'bi-person-x' : 'bi-person-check' %> me-1"></i>
                          <%= user.isActive ? 'Deactivate' : 'Activate' %>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
