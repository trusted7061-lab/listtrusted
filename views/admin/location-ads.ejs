<div class="admin-section">
  <div class="container py-5" style="margin-top: 70px;">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-1">Location Ads <span class="gradient-text">Management</span></h2>
        <p class="text-muted mb-0">Manage featured ads for location pages</p>
      </div>
      <a href="/admin/location-ads/create" class="btn btn-primary rounded-pill">
        <i class="bi bi-plus-circle me-2"></i>Create New Ad
      </a>
    </div>

    <!-- Filters/Search -->
    <div class="card border-0 shadow-sm mb-4 p-3">
      <div class="row g-3">
        <div class="col-md-6">
          <input type="text" class="form-control" id="searchInput" placeholder="Search ads by title...">
        </div>
        <div class="col-md-3">
          <select class="form-select" id="statusFilter">
            <option value="">All Status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
            <option value="expired">Expired</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Ads Table -->
    <div class="table-responsive card border-0 shadow-sm">
      <% if (locationAds && locationAds.length > 0) { %>
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>Image</th>
              <th>Target Cities</th>
              <th>Status</th>
              <th>Dates</th>
              <th>Clicks</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% locationAds.forEach(ad => { %>
              <% const now = new Date(); %>
              <% const isExpired = ad.endDate < now; %>
              <% const isActive = ad.isActive && !isExpired; %>
              <tr>
                <td><small class="text-muted"><%= ad._id.toString().substring(0, 8) %>...</small></td>
                <td>
                  <div class="fw-semibold"><%= ad.title %></div>
                  <% if (ad.description) { %>
                    <small class="text-muted"><%= ad.description.substring(0, 40) %>...</small>
                  <% } %>
                </td>
                <td>
                  <img src="<%= ad.image %>" alt="<%= ad.title %>" style="max-height: 50px; border-radius: 4px;">
                </td>
                <td>
                  <% if (ad.targetCities.length === 0) { %>
                    <span class="badge bg-info-subtle text-info">All Cities</span>
                  <% } else { %>
                    <div class="d-flex flex-wrap gap-1">
                      <% ad.targetCities.slice(0, 2).forEach(city => { %>
                        <span class="badge bg-primary-subtle text-primary"><small><%= city %></small></span>
                      <% }) %>
                      <% if (ad.targetCities.length > 2) { %>
                        <span class="badge bg-secondary-subtle text-secondary"><small>+<%= ad.targetCities.length - 2 %></small></span>
                      <% } %>
                    </div>
                  <% } %>
                </td>
                <td>
                  <% if (isExpired) { %>
                    <span class="badge bg-danger">Expired</span>
                  <% } else if (isActive) { %>
                    <span class="badge bg-success">Active</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% } %>
                </td>
                <td>
                  <small class="text-muted">
                    <%= new Date(ad.startDate).toLocaleDateString('en-IN') %><br>
                    to <%= new Date(ad.endDate).toLocaleDateString('en-IN') %>
                  </small>
                </td>
                <td>
                  <div class="fw-semibold"><%= ad.clicks || 0 %></div>
                  <small class="text-muted"><%= ad.impressions || 0 %> impressions</small>
                </td>
                <td>
                  <div class="btn-group btn-group-sm" role="group">
                    <a href="/admin/location-ads/<%= ad._id %>/edit" class="btn btn-outline-primary" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form method="POST" action="/admin/location-ads/<%= ad._id %>/delete" style="display:inline;">
                      <button type="submit" class="btn btn-outline-danger" title="Delete" onclick="return confirm('Delete this ad?')">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="text-center py-5">
          <i class="bi bi-collection display-1 text-muted opacity-50 mb-3 d-block"></i>
          <h5 class="fw-bold mb-2">No Location Ads Yet</h5>
          <p class="text-muted mb-4">Create your first featured location ad to get started.</p>
          <a href="/admin/location-ads/create" class="btn btn-primary rounded-pill">
            <i class="bi bi-plus-circle me-2"></i>Create First Ad
          </a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
  .stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
  }
  
  .table-hover tbody tr:hover {
    background-color: #f8f9fa;
  }
</style>
