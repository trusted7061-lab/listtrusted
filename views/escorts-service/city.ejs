<!-- Breadcrumb -->
<div class="container" style="margin-top: 80px; padding-top: 16px;">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item"><a href="/escorts-service/" class="text-decoration-none">Escorts Service India</a></li>
      <li class="breadcrumb-item active">Escort Service in <%= city.name %></li>
    </ol>
  </nav>
</div>

<!-- Answer Box — Featured Snippet / Voice Search target -->
<div class="container mt-2 mb-1">
  <div class="answer-box city-answer speakable-content p-3 p-md-4 rounded-4 bg-white border border-primary-subtle shadow-sm" itemscope itemtype="https://schema.org/Answer">
    <div class="d-flex align-items-start gap-3">
      <i class="bi bi-geo-alt-fill fs-4 text-primary flex-shrink-0 mt-1"></i>
      <p class="mb-0 text-muted"><strong>Escort service in <%= city.name %></strong> — Find <%= ads.length > 0 ? ads.length + '+' : 'verified' %> admin-approved escort service listings in <%= city.name %>, <%= city.state %> on Trusted Escort India. Browse profiles below and contact directly via Call or WhatsApp — no middlemen, available 24/7. Every listing is manually reviewed for authenticity.</p>
    </div>
  </div>
</div>

<!-- Hero -->
<section class="location-hero py-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-7" data-aos="fade-right">
        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">
          <i class="bi bi-geo-alt-fill me-1"></i><%= city.name %>, <%= city.state %>
        </span>
        <h1 class="display-4 fw-800 mb-3">
          Escort Service in <span class="gradient-text"><%= city.name %></span>
        </h1>
        <p class="lead text-muted mb-4">
          Find verified, premium escort service in <%= city.name %>. All profiles admin-reviewed and approved — safe, discreet, quality guaranteed.
        </p>
        <div class="d-flex gap-3 flex-wrap mb-4">
          <a href="/auth/register" class="btn btn-primary btn-lg rounded-pill px-4 shadow">
            <i class="bi bi-megaphone me-2"></i>Post Ad in <%= city.name %>
          </a>
          <a href="#listings" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
            <i class="bi bi-grid me-2"></i>Browse Listings
          </a>
        </div>

        <!-- Hero Search Bar -->
        <% var _hsbCats = ['Escort Service','Call Girls','VIP Escorts','Celebrity Escorts','College Girls','Russian Escorts','Housewife','Model']; %>
        <% var _hsbStates = cities.reduce(function(a,c){if(a.indexOf(c.state)<0)a.push(c.state);return a;},[]).sort(); %>
        <div class="d-flex gap-4">
          <div>
            <h5 class="fw-bold mb-0 gradient-text"><%= ads.length %>+</h5>
            <small class="text-muted">Active Listings</small>
          </div>
          <div class="vr"></div>
          <div>
            <h5 class="fw-bold mb-0 gradient-text">100%</h5>
            <small class="text-muted">Verified</small>
          </div>
          <div class="vr"></div>
          <div>
            <h5 class="fw-bold mb-0 gradient-text">24/7</h5>
            <small class="text-muted">Available</small>
          </div>
        </div>
      </div>
      <div class="col-lg-5 text-center d-none d-lg-block" data-aos="fade-left">
        <div class="location-hero-visual">
          <i class="bi bi-geo-alt-fill display-1 gradient-text"></i>
          <h3 class="fw-bold mt-3"><%= city.name %></h3>
          <p class="text-muted mb-0"><%= city.state %></p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Full-width Search Bar -->
<section class="py-4" style="background:var(--gradient-hero);">
  <div class="container">
    <form class="hero-search-bar mx-auto" action="/search" method="GET" novalidate>
      <div class="hsb-field">
        <select class="hsb-select hsb-category-select" name="q" aria-label="Category">
          <option value="">All Categories</option>
          <% _hsbCats.forEach(function(cat){ %><option value="<%= cat %>"><%= cat %></option><% }) %>
        </select>
      </div>
      <div class="hsb-divider"></div>
      <div class="hsb-field">
        <select class="hsb-select hsb-state-select" name="state" aria-label="State">
          <option value="">Select State</option>
          <% _hsbStates.forEach(function(s){ %><option value="<%= s %>" <%= s === city.state ? 'selected' : '' %>><%= s %></option><% }) %>
        </select>
      </div>
      <div class="hsb-divider"></div>
      <div class="hsb-field">
        <select class="hsb-select hsb-city-select" name="city" aria-label="City">
          <option value="">Select City</option>
          <% cities.forEach(function(c){ %><option value="<%= c.slug %>" data-state="<%= c.state %>" <%= c.slug === city.slug ? 'selected' : '' %>><%= c.name %></option><% }) %>
        </select>
      </div>
      <button type="submit" class="hsb-btn"><i class="bi bi-search me-1"></i>Search</button>
    </form>
  </div>
</section>

<!-- Sub-Areas (if available) -->
<% if (areas && areas.length > 0) { %>
<section class="py-4 border-bottom">
  <div class="container">
    <h5 class="fw-semibold mb-3">
      <i class="bi bi-pin-map-fill me-2 text-primary"></i>Escort Service by Area in <%= city.name %>
    </h5>
    <div class="d-flex flex-wrap gap-2">
      <% areas.forEach(area => { %>
        <a href="/escorts-service/<%= city.slug %>/<%= area.slug %>/" class="area-pill text-decoration-none">
          <i class="bi bi-geo-alt me-1"></i><%= area.name %>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Listings -->
<section id="listings" class="py-5 bg-light-subtle">
  <div class="container">
    <div class="text-center mb-5" data-aos="fade-up">
      <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill mb-3">
        <i class="bi bi-patch-check me-1"></i>Admin Verified Listings
      </span>
      <h2 class="display-5 fw-bold">Escort Service in <span class="gradient-text"><%= city.name %></span></h2>
      <p class="lead text-muted">All listings below are approved by our admin team</p>
    </div>

    <!-- Featured Location Ads -->
    <% if (locationAds && locationAds.length > 0) { %>
      <div class="row g-4 mb-5">
        <% locationAds.forEach((ad, i) => { %>
          <div class="col-lg-6" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
            <div class="location-ad-card card border-2 border-warning h-100 overflow-hidden shadow-lg position-relative">
              <div class="featured-badge position-absolute top-0 end-0 m-3">
                <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Featured</span>
              </div>
              <a href="<%= ad.link %>" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                <img src="<%= ad.image %>" class="card-img-top" width="400" height="200" style="height: 200px; object-fit: cover;" loading="lazy" decoding="async"
                     alt="<%= ad.title %>">
              </a>
              <div class="card-body">
                <h5 class="card-title fw-bold mb-2"><%= ad.title %></h5>
                <% if (ad.description) { %>
                  <p class="card-text text-muted small mb-3"><%= ad.description %></p>
                <% } %>
                <a href="<%= ad.link %>" target="_blank" rel="noopener noreferrer" class="btn btn-warning btn-sm rounded-pill w-100">
                  <i class="bi bi-arrow-right me-1"></i>Learn More
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (ads && ads.length > 0) { %>
      <div class="row g-4">
        <% ads.forEach((ad, i) => { %>
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="<%= (i % 6) * 80 %>">
