          <% } %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5" data-aos="fade-up">
        <i class="bi bi-megaphone display-1 gradient-text opacity-50 mb-3 d-block"></i>
        <h3 class="fw-bold mb-2">Be the First in <%= city.name %>!</h3>
