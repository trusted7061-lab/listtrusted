<!-- Breadcrumb -->
<div class="container" style="margin-top: 80px; padding-top: 16px;">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item"><a href="/escorts-service/" class="text-decoration-none">Escorts Service India</a></li>
      <li class="breadcrumb-item"><a href="/escorts-service/<%= city.slug %>/" class="text-decoration-none">Escort Service in <%= city.name %></a></li>
      <li class="breadcrumb-item active">Escort Service in <%= area.name %></li>
    </ol>
  </nav>
</div>

<!-- Hero -->
<section class="location-hero py-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-7" data-aos="fade-right">
        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">
          <i class="bi bi-geo-alt-fill me-1"></i><%= area.name %>, <%= city.name %>
        </span>
        <h1 class="display-4 fw-800 mb-3">
          Escort Service in <span class="gradient-text"><%= area.name %></span>, <%= city.name %>
        </h1>
        <p class="lead text-muted mb-4">
          Find verified escort service in <strong><%= area.name %></strong>, <%= city.name %>.
          All listings are admin-approved — safe, discreet, and reliable.
        </p>
        <div class="d-flex gap-3 flex-wrap mb-4">
          <a href="/auth/register" class="btn btn-primary btn-lg rounded-pill px-4 shadow">
            <i class="bi bi-megaphone me-2"></i>Post Ad — <%= area.name %>
          </a>
          <a href="#listings" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
            <i class="bi bi-grid me-2"></i>Browse Listings
          </a>
        </div>
        <div class="d-flex gap-4">
          <div>
            <h5 class="fw-bold mb-0 gradient-text"><%= ads.length %>+</h5>
            <small class="text-muted">Active Listings</small>
          </div>
          <div class="vr"></div>
          <div>
            <h5 class="fw-bold mb-0 gradient-text">100%</h5>
            <small class="text-muted">Verified</small>
          </div>
          <div class="vr"></div>
          <div>
            <h5 class="fw-bold mb-0 gradient-text">24/7</h5>
            <small class="text-muted">Available</small>
          </div>
        </div>
      </div>
      <div class="col-lg-5 d-none d-lg-block text-center" data-aos="fade-left">
        <div class="location-hero-visual">
          <i class="bi bi-geo-alt-fill display-1 gradient-text"></i>
          <h3 class="fw-bold mt-3"><%= area.name %></h3>
          <p class="text-muted mb-0"><%= city.name %>, <%= city.state %></p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Other Areas in same City -->
<% if (otherAreas && otherAreas.length > 0) { %>
<section class="py-3 border-bottom">
  <div class="container">
    <h5 class="fw-semibold mb-3">
      <i class="bi bi-pin-map-fill me-2 text-primary"></i>
      Other Areas in <%= city.name %>:
    </h5>
    <div class="d-flex flex-wrap gap-2">
      <a href="/escorts-service/<%= city.slug %>/"
         class="area-pill text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i>All <%= city.name %>
      </a>
      <% otherAreas.forEach(a => { %>
        <a href="/escorts-service/<%= city.slug %>/<%= a.slug %>/"
           class="area-pill text-decoration-none <%= a.slug === area.slug ? 'active' : '' %>">
          <i class="bi bi-geo-alt me-1"></i><%= a.name %>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Listings -->
<section id="listings" class="py-5 bg-light-subtle">
  <div class="container">
    <div class="text-center mb-5" data-aos="fade-up">
      <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill mb-3">
        <i class="bi bi-patch-check me-1"></i>Admin Verified Listings
      </span>
      <h2 class="display-5 fw-bold">
        Escort Service in <span class="gradient-text"><%= area.name %></span>
      </h2>
      <p class="lead text-muted"><%= city.name %>, <%= city.state %> — Verified profiles only</p>
    </div>

    <% if (ads && ads.length > 0) { %>
      <div class="row g-4">
        <% ads.forEach((ad, i) => { %>
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="<%= (i % 6) * 80 %>">
            <div class="ad-card card border-0 shadow-sm h-100 overflow-hidden">
              <div class="ad-card-img-wrapper">
                <a href="/escorts-service/profile/<%= ad._id %>">
                  <img src="<%= ad.image %>" class="card-img-top" loading="lazy" decoding="async"
                       alt="<%= ad.title %> — Escort Service in <%= area.name %>, <%= city.name %>">
                </a>
                <span class="ad-type-badge"><%= ad.category %></span>
                <span class="city-badge">
                  <i class="bi bi-geo-alt-fill me-1"></i><%= area.name %>, <%= city.name %>
                </span>
              </div>
              <div class="card-body p-4">
                <h5 class="fw-semibold mb-2"><%= ad.title %></h5>
                <p class="text-muted small mb-3">
                  <%= ad.description.substring(0, 120) %><%= ad.description.length > 120 ? '...' : '' %>
                </p>
                <% const phoneHref = ad.phoneNumber    ? ad.phoneNumber.replace(/[^\d+]/g, '')    : '' %>
                <% const waHref    = ad.whatsappNumber ? ad.whatsappNumber.replace(/\D/g, '')       : '' %>
                <div class="d-flex flex-column gap-2 mb-3">
                  <% if (ad.showPhoneNumber && ad.phoneNumber) { %>
                    <a href="tel:<%= phoneHref %>" class="btn btn-outline-primary btn-sm rounded-pill">
                      <i class="bi bi-telephone-fill me-1"></i>Call <%= ad.phoneNumber %>
                    </a>
                  <% } %>
                  <% if (ad.showWhatsappNumber && ad.whatsappNumber) { %>
                    <a href="https://wa.me/<%= waHref %>"
                       target="_blank" rel="noopener noreferrer"
                       class="btn btn-success btn-sm rounded-pill">
                      <i class="bi bi-whatsapp me-1"></i>WhatsApp <%= ad.whatsappNumber %>
                    </a>
                  <% } %>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                  <small class="text-muted">
                    <i class="bi bi-person-circle me-1"></i>
                    <%= ad.advertiser ? ad.advertiser.name : 'Verified Advertiser' %>
                  </small>
                  <span class="badge bg-success-subtle text-success small">
                    <i class="bi bi-patch-check-fill me-1"></i>Verified
                  </span>
                </div>
                <a href="/escorts-service/profile/<%= ad._id %>" class="btn btn-primary btn-sm rounded-pill w-100 mt-3">
                  <i class="bi bi-person-lines-fill me-1"></i>View Full Profile
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5" data-aos="fade-up">
        <i class="bi bi-megaphone display-1 gradient-text opacity-50 mb-3 d-block"></i>
        <h3 class="fw-bold mb-2">Be the First in <%= area.name %>!</h3>
        <p class="lead text-muted mb-4">
          No listings in <%= area.name %> yet. Post your ad and get first-mover advantage.
        </p>
        <a href="/auth/register" class="btn btn-primary btn-lg rounded-pill px-5 shadow">
          <i class="bi bi-rocket-takeoff me-2"></i>Post Free Ad in <%= area.name %>
        </a>
      </div>
    <% } %>
  </div>
</section>

