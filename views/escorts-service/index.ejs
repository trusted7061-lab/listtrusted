<!-- Hero -->
<section class="location-hero py-5">
  <div class="container">
    <div class="text-center" data-aos="fade-up">
      <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">
        <i class="bi bi-geo-alt-fill me-1"></i>Pan India Coverage
      </span>
      <h1 class="display-4 fw-800 mb-3">
        Escorts Service <span class="gradient-text">Near Me in India</span>
      </h1>
      <p class="lead text-muted mx-auto mb-4" style="max-width:650px;">
        Find verified escort service listings in 75+ cities across India. Every profile is admin-reviewed before going live — safe, discreet and premium quality.
      </p>
      <a href="/auth/register" class="btn btn-primary btn-lg rounded-pill px-5 shadow me-3">
        <i class="bi bi-megaphone me-2"></i>Post Free Ad
      </a>
      <a href="#all-cities" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
        <i class="bi bi-grid me-2"></i>Browse All Cities
      </a>

      <!-- Search Bar -->
      <form action="/search" method="GET" class="site-search-form mx-auto mt-4" style="max-width:680px;">
        <div class="site-search-wrap d-flex align-items-center gap-2">
          <div class="site-search-input-wrap flex-grow-1 d-flex align-items-center">
            <i class="bi bi-search site-search-icon"></i>
            <input type="text" name="q" placeholder="Search escorts, city, services…" class="site-search-input" autocomplete="off" maxlength="100">
          </div>
          <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold">Search</button>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- Metro Cities -->
<section class="py-5 bg-light-subtle" id="all-cities">
  <div class="container">
    <div class="text-center mb-4" data-aos="fade-up">
      <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill mb-2">Top Metro Cities</span>
      <h2 class="fw-bold">Escorts Service in <span class="gradient-text">Metro Cities</span></h2>
    </div>
    <div class="row g-3 mb-5">
      <% cities.filter(c => c.metro).forEach((city, i) => { %>
        <div class="col-6 col-sm-4 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="<%= i * 40 %>">
          <a href="/escorts-service/<%= city.slug %>/" class="city-card d-flex flex-column align-items-center text-center p-3 rounded-3 text-decoration-none h-100">
            <i class="bi bi-building fs-2 mb-2 gradient-text"></i>
            <span class="fw-semibold small">Escorts in</span>
            <strong class="small"><%= city.name %></strong>
            <small class="text-muted x-small mt-1"><%= city.state %></small>
          </a>
        </div>
      <% }) %>
    </div>

    <!-- All Cities by State grouped -->
    <div class="text-center mb-4" data-aos="fade-up">
      <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-2">All 75+ Cities</span>
      <h2 class="fw-bold">Escort Service <span class="gradient-text">All India</span></h2>
    </div>

    <%
      // Group non-metro cities by state
      const stateMap = {};
      cities.filter(c => !c.metro).forEach(city => {
        if (!stateMap[city.state]) stateMap[city.state] = [];
        stateMap[city.state].push(city);
      });
    %>

    <div class="row g-4">
      <% Object.entries(stateMap).forEach(([state, stateCities]) => { %>
        <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up">
          <div class="state-group-card p-3 rounded-3">
            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
              <i class="bi bi-map-fill text-primary small"></i><%= state %>
            </h6>
            <div class="d-flex flex-wrap gap-2">
              <% stateCities.forEach(city => { %>
                <a href="/escorts-service/<%= city.slug %>/" class="city-pill text-decoration-none">
                  <i class="bi bi-geo-alt-fill me-1"></i><%= city.name %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

