          <div class="ad-card card border-0 shadow-sm h-100 overflow-hidden">
            <div class="ad-card-img-wrapper">
              <a href="/escorts-service/profile/<%= ad._id %>">
                <img src="<%= ad.image %>" class="card-img-top" width="400" height="260" alt="<%= ad.title %>" loading="lazy" decoding="async">
              </a>
              <span class="ad-type-badge"><%= ad.category %></span>
            </div>
            <div class="card-body p-4">
              <h6 class="fw-semibold mb-2"><%= ad.title %></h6>
              <p class="text-muted small mb-3"><%= ad.description.substring(0, 100) %><%= ad.description.length > 100 ? '...' : '' %></p>
              <% const phoneHref = ad.phoneNumber ? ad.phoneNumber.replace(/[^\d+]/g, '') : '' %>
              <% const whatsappHref = ad.whatsappNumber ? ad.whatsappNumber.replace(/\D/g, '') : '' %>
              <% if ((ad.showPhoneNumber && ad.phoneNumber) || (ad.showWhatsappNumber && ad.whatsappNumber)) { %>
                <div class="small mb-3">
                  <% if (ad.showPhoneNumber && ad.phoneNumber) { %>
                    <div class="mb-2">
                      <a href="tel:<%= phoneHref %>" class="btn btn-sm btn-outline-primary rounded-pill">
                        <i class="bi bi-telephone me-1"></i>Call <%= ad.phoneNumber %>
                      </a>
                    </div>
                  <% } %>
                  <% if (ad.showWhatsappNumber && ad.whatsappNumber) { %>
                    <div>
                      <a href="https://wa.me/<%= whatsappHref %>" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-success rounded-pill">
                        <i class="bi bi-whatsapp me-1"></i>WhatsApp <%= ad.whatsappNumber %>
                      </a>
                    </div>
                  <% } %>
                </div>
              <% } %>
              <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">
                  <i class="bi bi-person me-1"></i><%= ad.advertiser ? ad.advertiser.name : 'Unknown' %>
                </small>
                <span class="badge bg-success-subtle text-success">
                  <i class="bi bi-check-circle me-1"></i>Approved
                </span>
              </div>
              <a href="/escorts-service/profile/<%= ad._id %>" class="btn btn-primary btn-sm rounded-pill w-100 mt-3">
                <i class="bi bi-person-lines-fill me-1"></i>View Full Profile
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

