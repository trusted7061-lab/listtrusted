<!-- Cities We Serve -->
<section class="py-5 bg-light-subtle">
  <div class="container">
    <div class="text-center mb-4" data-aos="fade-up">
      <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">Available Across India</span>
      <h2 class="display-5 fw-bold">Escorts Service <span class="gradient-text">Near Me</span></h2>
      <p class="lead text-muted mx-auto" style="max-width:620px;">Find premium escorts service in your city. We cover 70+ locations across India.</p>
    </div>

    <!-- Metro Cities -->
    <h6 class="fw-semibold text-muted text-uppercase small mb-3 mt-4">Metro & Tier-1 Cities</h6>
    <div class="row g-3 mb-4">
      <% cities.filter(c => c.metro).forEach((city, i) => { %>
        <div class="col-6 col-sm-4 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="<%= i * 40 %>">
          <a href="/escorts-service/<%= city.slug %>" class="city-card d-flex flex-column align-items-center text-center p-3 rounded-3 text-decoration-none h-100">
            <i class="bi bi-building fs-3 mb-2 gradient-text"></i>
            <span class="fw-semibold small">Escorts in<br><strong><%= city.name %></strong></span>
          </a>
        </div>
      <% }) %>
    </div>

    <!-- All Other Cities -->
    <h6 class="fw-semibold text-muted text-uppercase small mb-3">All India Cities</h6>
    <div class="row g-2">
      <% cities.filter(c => !c.metro).forEach((city, i) => { %>
        <div class="col-6 col-sm-4 col-md-3 col-lg-2" data-aos="fade-up" data-aos-delay="<%= (i % 12) * 30 %>">
          <a href="/escorts-service/<%= city.slug %>" class="city-card-sm d-flex align-items-center gap-2 p-2 rounded-3 text-decoration-none">
            <i class="bi bi-geo-alt-fill text-primary small"></i>
            <span class="small fw-medium"><%= city.name %></span>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- How It Works -->
<section id="how-it-works" class="py-6">
  <div class="container">
    <div class="text-center mb-5" data-aos="fade-up">
      <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">Simple Process</span>
      <h2 class="display-5 fw-bold">How It <span class="gradient-text">Works</span></h2>
      <p class="lead text-muted mx-auto" style="max-width: 600px;">Three simple steps to get your ads in front of the right audience</p>
    </div>
    <div class="row g-4">
      <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
        <div class="step-card text-center p-4">
          <div class="step-number">1</div>
          <div class="step-icon mb-3">
            <i class="bi bi-person-plus-fill"></i>
          </div>
          <h5 class="fw-semibold">Create Account</h5>
          <p class="text-muted">Sign up as an advertiser in seconds. Fill in your details and you're ready to go.</p>
        </div>
      </div>
      <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
        <div class="step-card text-center p-4">
          <div class="step-number">2</div>
          <div class="step-icon mb-3">
            <i class="bi bi-cloud-arrow-up-fill"></i>
          </div>
          <h5 class="fw-semibold">Submit Your Ad</h5>
          <p class="text-muted">Upload your ad image, add details, set schedule, and choose your ad type.</p>
        </div>
      </div>
      <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
        <div class="step-card text-center p-4">
          <div class="step-number">3</div>
          <div class="step-icon mb-3">
            <i class="bi bi-patch-check-fill"></i>
          </div>
          <h5 class="fw-semibold">Get Approved</h5>
          <p class="text-muted">Our admin team reviews your ad for quality. Once approved, it goes live!</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Ad Types -->
<section class="py-6">
  <div class="container">
    <div class="text-center mb-5" data-aos="fade-up">
      <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">Flexible Options</span>
      <h2 class="display-5 fw-bold">Ad <span class="gradient-text">Types</span></h2>
      <p class="lead text-muted">Choose the format that works best for your campaign</p>
    </div>
    <div class="row g-4">
      <% const adTypes = [
        { icon: 'bi-image', name: 'Banner', desc: 'Classic display banners for websites and apps', iconClass: 'text-primary bg-primary-subtle' },
        { icon: 'bi-camera-video', name: 'Video', desc: 'Engaging video ads that capture attention', iconClass: 'text-danger bg-danger-subtle' },
        { icon: 'bi-window-stack', name: 'Popup', desc: 'Attention-grabbing popup advertisements', iconClass: 'text-warning bg-warning-subtle' },
        { icon: 'bi-layout-text-sidebar', name: 'Native', desc: 'Ads that blend naturally with content', iconClass: 'text-success bg-success-subtle' },
        { icon: 'bi-share', name: 'Social Media', desc: 'Optimized for social platform sharing', iconClass: 'text-info bg-info-subtle' },
        { icon: 'bi-envelope-open', name: 'Email', desc: 'Professional email campaign creatives', iconClass: 'text-primary-emphasis bg-primary-subtle' }
      ] %>
      <% adTypes.forEach((type, i) => { %>
        <div class="col-md-4 col-sm-6" data-aos="zoom-in" data-aos-delay="<%= i * 100 %>">
          <div class="type-card p-4 h-100">
            <div class="type-icon mb-3 <%= type.iconClass %>">
              <i class="bi <%= type.icon %>"></i>
            </div>
            <h5 class="fw-semibold"><%= type.name %></h5>
            <p class="text-muted mb-0 small"><%= type.desc %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Featured Ads -->
<% if (ads && ads.length > 0) { %>
<section class="py-6 bg-light-subtle">
  <div class="container">
    <div class="text-center mb-5" data-aos="fade-up">
      <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill mb-3">Live Now</span>
      <h2 class="display-5 fw-bold">Featured <span class="gradient-text">Ads</span></h2>
      <p class="lead text-muted">Recently approved advertisements on our platform</p>
    </div>
    <div class="row g-4">
      <% ads.forEach((ad, i) => { %>
        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
          <div class="ad-card card border-0 shadow-sm h-100 overflow-hidden">
            <div class="ad-card-img-wrapper">
              <img src="<%= ad.image %>" class="card-img-top" alt="<%= ad.title %>">
              <span class="ad-type-badge"><%= ad.category %></span>
            </div>
            <div class="card-body p-4">
              <h6 class="fw-semibold mb-2"><%= ad.title %></h6>
              <p class="text-muted small mb-3"><%= ad.description.substring(0, 100) %><%= ad.description.length > 100 ? '...' : '' %></p>
              <% const phoneHref = ad.phoneNumber ? ad.phoneNumber.replace(/[^\d+]/g, '') : '' %>
              <% const whatsappHref = ad.whatsappNumber ? ad.whatsappNumber.replace(/\D/g, '') : '' %>
              <% if ((ad.showPhoneNumber && ad.phoneNumber) || (ad.showWhatsappNumber && ad.whatsappNumber)) { %>
                <div class="small mb-3">
                  <% if (ad.showPhoneNumber && ad.phoneNumber) { %>
                    <div class="mb-2">
                      <a href="tel:<%= phoneHref %>" class="btn btn-sm btn-outline-primary rounded-pill">
                        <i class="bi bi-telephone me-1"></i>Call <%= ad.phoneNumber %>
                      </a>
                    </div>
                  <% } %>
                  <% if (ad.showWhatsappNumber && ad.whatsappNumber) { %>
                    <div>
                      <a href="https://wa.me/<%= whatsappHref %>" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-success rounded-pill">
                        <i class="bi bi-whatsapp me-1"></i>WhatsApp <%= ad.whatsappNumber %>
                      </a>
                    </div>
                  <% } %>
                </div>
              <% } %>
              <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">
                  <i class="bi bi-person me-1"></i><%= ad.advertiser ? ad.advertiser.name : 'Unknown' %>
                </small>
                <span class="badge bg-success-subtle text-success">
                  <i class="bi bi-check-circle me-1"></i>Approved
                </span>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

