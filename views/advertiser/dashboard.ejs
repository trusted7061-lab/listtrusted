<div class="dashboard-section">
  <div class="container py-5" style="margin-top: 70px;">
    <!-- Welcome Header -->
    <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
      <div>
        <h1 class="fw-bold mb-1">Welcome, <span class="gradient-text"><%= currentUser.name %></span></h1>
        <p class="text-muted mb-0">Here's an overview of your advertising activity</p>
      </div>
      <a href="/advertiser/create-ad" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-lg me-2"></i>New Ad
      </a>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
      <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="100">
        <div class="stat-card card border-0 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <p class="text-muted small mb-1">Total Ads</p>
                <h3 class="fw-bold mb-0"><%= stats.total %></h3>
              </div>
              <div class="stat-icon bg-primary-subtle text-primary">
                <i class="bi bi-collection"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="200">
        <div class="stat-card card border-0 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <p class="text-muted small mb-1">Pending</p>
                <h3 class="fw-bold mb-0 text-warning"><%= stats.pending %></h3>
              </div>
              <div class="stat-icon bg-warning-subtle text-warning">
                <i class="bi bi-clock-history"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="300">
        <div class="stat-card card border-0 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <p class="text-muted small mb-1">Approved</p>
                <h3 class="fw-bold mb-0 text-success"><%= stats.approved %></h3>
              </div>
              <div class="stat-icon bg-success-subtle text-success">
                <i class="bi bi-check-circle"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="400">
        <div class="stat-card card border-0 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <p class="text-muted small mb-1">Rejected</p>
                <h3 class="fw-bold mb-0 text-danger"><%= stats.rejected %></h3>
              </div>
              <div class="stat-icon bg-danger-subtle text-danger">
                <i class="bi bi-x-circle"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Ads -->
    <div class="card border-0 shadow-sm" data-aos="fade-up">
      <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="fw-semibold mb-0"><i class="bi bi-clock-history me-2"></i>Recent Ads</h5>
          <a href="/advertiser/my-ads" class="btn btn-sm btn-outline-primary rounded-pill">View All</a>
        </div>
      </div>
      <div class="card-body p-4">
        <% if (ads.length === 0) { %>
          <div class="text-center py-5">
            <div class="empty-state-icon mb-3">
              <i class="bi bi-megaphone"></i>
            </div>
            <h5 class="text-muted">No ads yet</h5>
            <p class="text-muted">Create your first ad to get started!</p>
            <a href="/advertiser/create-ad" class="btn btn-primary rounded-pill px-4">
              <i class="bi bi-plus-lg me-2"></i>Create Your First Ad
            </a>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Ad</th>
                  <th>Type</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% ads.forEach(ad => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <img src="<%= ad.image %>" alt="<%= ad.title %> thumbnail" width="50" height="50" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;" loading="lazy" decoding="async">
                        <div>
                          <h6 class="mb-0 fw-semibold"><%= ad.title %></h6>
                          <small class="text-muted"><%= ad.description.substring(0, 40) %>...</small>
                        </div>
                      </div>
                    </td>
                    <td><span class="badge bg-light text-dark"><%= ad.category %></span></td>
                    <td>
                      <% if (ad.status === 'pending') { %>
                        <span class="badge bg-warning-subtle text-warning"><i class="bi bi-clock me-1"></i>Pending</span>
                      <% } else if (ad.status === 'approved') { %>
                        <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i>Approved</span>
                      <% } else { %>
                        <span class="badge bg-danger-subtle text-danger"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                      <% } %>
                    </td>
                    <td><small class="text-muted"><%= new Date(ad.createdAt).toLocaleDateString() %></small></td>
                    <td>
                      <% if (ad.status === 'pending') { %>
                        <a href="/advertiser/edit-ad/<%= ad._id %>" class="btn btn-sm btn-outline-primary me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
