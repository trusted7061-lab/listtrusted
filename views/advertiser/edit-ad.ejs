<div class="dashboard-section">
  <div class="container py-5" style="margin-top: 70px;">
    <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
      <div>
        <h1 class="fw-bold mb-1"><i class="bi bi-pencil-square me-2 gradient-text"></i>Edit Ad</h1>
        <p class="text-muted mb-0">Update your advertisement details</p>
      </div>
      <a href="/advertiser/my-ads" class="btn btn-outline-secondary rounded-pill px-3">
        <i class="bi bi-arrow-left me-1"></i>Back
      </a>
    </div>

    <div class="card border-0 shadow-sm" data-aos="fade-up">
      <div class="card-body p-4 p-lg-5">
        <form method="POST" action="/advertiser/edit-ad/<%= ad._id %>" enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-medium">Ad Title <span class="text-danger">*</span></label>
              <input type="text" name="title" class="form-control form-control-lg" value="<%= ad.title %>" required maxlength="100">
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Description <span class="text-danger">*</span></label>
              <textarea name="description" class="form-control" rows="4" required maxlength="1000"><%= ad.description %></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Category / Type <span class="text-danger">*</span></label>
              <select name="category" class="form-select" required>
                <% ['Banner','Video','Popup','Native','Social Media','Search','Email'].forEach(cat => { %>
                  <option value="<%= cat %>" <%= ad.category === cat ? 'selected' : '' %>><%= cat %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Target Audience <span class="text-danger">*</span></label>
              <input type="text" name="targetAudience" class="form-control" value="<%= ad.targetAudience %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">City / Location</label>
              <select name="citySlug" id="citySlug" class="form-select">
                <option value="">— keep current city —</option>
                <% (typeof cities !== 'undefined' ? cities : []).forEach(function(city) { %>
                  <option value="<%= city.slug %>" <%= ad.citySlug === city.slug ? 'selected' : '' %>><%= city.name %>, <%= city.state %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Area / Locality <span class="text-muted small">(optional)</span></label>
              <select name="areaSlug" id="areaSlug" class="form-select">
                <option value="">All areas in city</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Current Image</label>
              <div class="mb-2">
                <img src="<%= ad.image %>" alt="Current" class="rounded" style="max-height: 200px;">
              </div>
              <label class="form-label fw-medium">Replace Image (optional)</label>
              <input type="file" name="image" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Start Date <span class="text-danger">*</span></label>
              <input type="date" name="startDate" class="form-control" value="<%= new Date(ad.startDate).toISOString().split('T')[0] %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">End Date <span class="text-danger">*</span></label>
              <input type="date" name="endDate" class="form-control" value="<%= new Date(ad.endDate).toISOString().split('T')[0] %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Budget ($)</label>
              <input type="number" name="budget" class="form-control" value="<%= ad.budget %>" min="0" step="0.01">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Landing URL</label>
              <input type="url" name="landingUrl" class="form-control" value="<%= ad.landingUrl || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Phone Number</label>
              <div class="input-group">
                <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                <input type="tel" name="phoneNumber" class="form-control" value="<%= ad.phoneNumber || '' %>" placeholder="+91 98765 43210">
              </div>
              <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" name="showPhoneNumber" id="showPhoneNumber" <%= ad.showPhoneNumber ? 'checked' : '' %>>
                <label class="form-check-label small" for="showPhoneNumber">Show phone number publicly on approved ads</label>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">WhatsApp Number</label>
              <div class="input-group">
                <span class="input-group-text bg-light"><i class="bi bi-whatsapp text-success"></i></span>
                <input type="tel" name="whatsappNumber" class="form-control" value="<%= ad.whatsappNumber || '' %>" placeholder="+91 98765 43210">
              </div>
              <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" name="showWhatsappNumber" id="showWhatsappNumber" <%= ad.showWhatsappNumber ? 'checked' : '' %>>
                <label class="form-check-label small" for="showWhatsappNumber">Show WhatsApp button publicly on approved ads</label>
              </div>
            </div>
            <div class="col-12">
              <div class="form-text">Contact options stay hidden unless their checkbox is enabled.</div>
            </div>
          </div>
          <hr>
          <div class="d-flex justify-content-end gap-3">
            <a href="/advertiser/my-ads" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
            <button type="submit" class="btn btn-primary rounded-pill px-4">
              <i class="bi bi-check-lg me-2"></i>Update Ad
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script>
(function () {
  const AREAS = <%- JSON.stringify(typeof areas !== 'undefined' ? areas : {}) %>;
  const preselectedArea = '<%= ad.areaSlug || "" %>';
  const citySelect = document.getElementById('citySlug');
  const areaSelect = document.getElementById('areaSlug');

  function populateAreas(citySlug) {
    const list = AREAS[citySlug] || [];
    areaSelect.innerHTML = '<option value="">All areas in city</option>';
    list.forEach(function (a) {
      const opt = document.createElement('option');
      opt.value = a.slug;
      opt.textContent = a.name;
      if (a.slug === preselectedArea) opt.selected = true;
      areaSelect.appendChild(opt);
    });
  }

  if (citySelect.value) populateAreas(citySelect.value);
  citySelect.addEventListener('change', function () { populateAreas(this.value); });
}());
</script>
