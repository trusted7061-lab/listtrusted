<div class="dashboard-section">
  <div class="container py-5" style="margin-top: 70px;">
    <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
      <div>
        <h1 class="fw-bold mb-1"><i class="bi bi-collection me-2 gradient-text"></i>My Ads</h1>
        <p class="text-muted mb-0">View and manage all your submitted advertisements</p>
      </div>
      <a href="/advertiser/create-ad" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-lg me-2"></i>New Ad
      </a>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4" data-aos="fade-up">
      <div class="card-body p-3">
        <div class="d-flex gap-2 flex-wrap">
          <a href="/advertiser/my-ads" class="btn btn-sm rounded-pill <%= !statusFilter ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>
          <a href="/advertiser/my-ads?status=pending" class="btn btn-sm rounded-pill <%= statusFilter === 'pending' ? 'btn-warning' : 'btn-outline-warning' %>">
            <i class="bi bi-clock me-1"></i>Pending
          </a>
          <a href="/advertiser/my-ads?status=approved" class="btn btn-sm rounded-pill <%= statusFilter === 'approved' ? 'btn-success' : 'btn-outline-success' %>">
            <i class="bi bi-check-circle me-1"></i>Approved
          </a>
          <a href="/advertiser/my-ads?status=rejected" class="btn btn-sm rounded-pill <%= statusFilter === 'rejected' ? 'btn-danger' : 'btn-outline-danger' %>">
            <i class="bi bi-x-circle me-1"></i>Rejected
          </a>
        </div>
      </div>
    </div>

    <% if (ads.length === 0) { %>
      <div class="text-center py-5" data-aos="fade-up">
        <div class="empty-state-icon mb-3">
          <i class="bi bi-inbox"></i>
        </div>
        <h5 class="text-muted">No ads found</h5>
        <p class="text-muted">
          <% if (statusFilter) { %>
            No <strong><%= statusFilter %></strong> ads. Try a different filter or create a new ad.
          <% } else { %>
            You haven't created any ads yet.
          <% } %>
        </p>
        <a href="/advertiser/create-ad" class="btn btn-primary rounded-pill px-4">
          <i class="bi bi-plus-lg me-2"></i>Create Ad
        </a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% ads.forEach((ad, i) => { %>
          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="<%= i * 50 %>">
            <div class="ad-card card border-0 shadow-sm h-100 overflow-hidden">
              <div class="ad-card-img-wrapper">
                <img src="<%= ad.image %>" class="card-img-top" alt="<%= ad.title %>" loading="lazy" decoding="async">
                <span class="ad-type-badge"><%= ad.category %></span>
                <% if (ad.status === 'pending') { %>
                  <span class="ad-status-badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Pending</span>
                <% } else if (ad.status === 'approved') { %>
                  <span class="ad-status-badge bg-success"><i class="bi bi-check-circle me-1"></i>Approved</span>
                <% } else { %>
                  <span class="ad-status-badge bg-danger"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                <% } %>
              </div>
              <div class="card-body p-4">
                <h6 class="fw-semibold mb-2"><%= ad.title %></h6>
                <p class="text-muted small mb-3"><%= ad.description.substring(0, 80) %><%= ad.description.length > 80 ? '...' : '' %></p>
                <% if (ad.phoneNumber || ad.whatsappNumber) { %>
                  <div class="small mb-3">
                    <% if (ad.phoneNumber) { %>
                      <div class="text-muted mb-1">
                        <i class="bi bi-telephone me-1"></i><%= ad.phoneNumber %>
                        <span class="badge rounded-pill ms-2 <%= ad.showPhoneNumber ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' %>">
                          <%= ad.showPhoneNumber ? 'Public' : 'Hidden' %>
                        </span>
                      </div>
                    <% } %>
                    <% if (ad.whatsappNumber) { %>
                      <div class="text-muted">
                        <i class="bi bi-whatsapp me-1 text-success"></i><%= ad.whatsappNumber %>
                        <span class="badge rounded-pill ms-2 <%= ad.showWhatsappNumber ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary' %>">
                          <%= ad.showWhatsappNumber ? 'Public' : 'Hidden' %>
                        </span>
                      </div>
                    <% } %>
                  </div>
                <% } %>
                <div class="d-flex justify-content-between align-items-center text-muted small mb-3">
                  <span><i class="bi bi-calendar me-1"></i><%= new Date(ad.startDate).toLocaleDateString() %> - <%= new Date(ad.endDate).toLocaleDateString() %></span>
                  <% if (ad.budget > 0) { %>
                    <span><i class="bi bi-currency-dollar me-1"></i><%= ad.budget %></span>
                  <% } %>
                </div>
                <% if (ad.adminNotes) { %>
                  <div class="alert alert-<%= ad.status === 'rejected' ? 'danger' : 'info' %> py-2 px-3 small mb-3">
                    <i class="bi bi-chat-left-text me-1"></i><strong>Admin:</strong> <%= ad.adminNotes %>
                  </div>
                <% } %>
                <div class="d-flex gap-2">
                  <% if (ad.status === 'pending') { %>
                    <a href="/advertiser/edit-ad/<%= ad._id %>" class="btn btn-sm btn-outline-primary rounded-pill flex-fill">
                      <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                  <% } %>
                  <form method="POST" action="/advertiser/delete-ad/<%= ad._id %>" onsubmit="return confirm('Are you sure you want to delete this ad?')" class="flex-fill">
                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill w-100">
                      <i class="bi bi-trash me-1"></i>Delete
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>
